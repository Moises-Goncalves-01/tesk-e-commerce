{
  "info": {
    "name": "Tech Store API",
    "description": "Coleção completa da API Tech Store para testes no Postman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3333",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "cartItemId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🧑 Usuários / Auth",
      "item": [
        {
          "name": "1. Cadastrar Usuário (Cliente)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao@email.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          },
          "response": []
        },
        {
          "name": "2. Login Cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "    console.log('✅ Token do cliente salvo automaticamente!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@email.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/session",
              "host": ["{{baseUrl}}"],
              "path": ["session"]
            }
          },
          "response": []
        },
        {
          "name": "3. Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('adminToken', jsonData.token);",
                  "    console.log('✅ Token do ADMIN salvo automaticamente!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@techstore.com\",\n  \"senha\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/session",
              "host": ["{{baseUrl}}"],
              "path": ["session"]
            }
          },
          "response": []
        },
        {
          "name": "4. Detalhes do Usuário Logado (GET /me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/me",
              "host": ["{{baseUrl}}"],
              "path": ["me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "📂 Categorias",
      "item": [
        {
          "name": "1. Criar Categoria (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.collectionVariables.set('categoryId', jsonData.id);",
                  "    console.log('✅ categoryId salvo: ' + jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Placas de Vídeo\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/category",
              "host": ["{{baseUrl}}"],
              "path": ["category"]
            }
          },
          "response": []
        },
        {
          "name": "2. Listar Categorias",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/category",
              "host": ["{{baseUrl}}"],
              "path": ["category"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "🛍️ Produtos",
      "item": [
        {
          "name": "1. Criar Produto (Admin - FormData)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.collectionVariables.set('productId', jsonData.id);",
                  "    console.log('✅ productId salvo: ' + jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "nome",
                  "value": "RTX 4090",
                  "type": "text"
                },
                {
                  "key": "descricao",
                  "value": "Placa de vídeo NVIDIA GeForce RTX 4090 24GB GDDR6X",
                  "type": "text"
                },
                {
                  "key": "preco",
                  "value": "12999.90",
                  "type": "text"
                },
                {
                  "key": "estoque",
                  "value": "15",
                  "type": "text"
                },
                {
                  "key": "categoria_id",
                  "value": "{{categoryId}}",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "(Opcional) Selecione uma imagem do produto"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/product",
              "host": ["{{baseUrl}}"],
              "path": ["product"]
            }
          },
          "response": []
        },
        {
          "name": "2. Listar Produtos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/product",
              "host": ["{{baseUrl}}"],
              "path": ["product"]
            }
          },
          "response": []
        },
        {
          "name": "3. Listar Produtos - c/ Filtro por Categoria",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/product?categoria_id={{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["product"],
              "query": [
                {
                  "key": "categoria_id",
                  "value": "{{categoryId}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "4. Listar Produtos - c/ Busca por Nome",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/product?search=RTX",
              "host": ["{{baseUrl}}"],
              "path": ["product"],
              "query": [
                {
                  "key": "search",
                  "value": "RTX"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "5. Listar Produtos - c/ Paginação",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/product?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["product"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "🛒 Carrinho",
      "item": [
        {
          "name": "1. Adicionar Item ao Carrinho",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.collectionVariables.set('cartItemId', jsonData.id);",
                  "    console.log('✅ cartItemId salvo: ' + jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"{{productId}}\",\n  \"quantidade\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": ["{{baseUrl}}"],
              "path": ["cart"]
            }
          },
          "response": []
        },
        {
          "name": "2. Listar Carrinho",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": ["{{baseUrl}}"],
              "path": ["cart"]
            }
          },
          "response": []
        },
        {
          "name": "3. Remover Item do Carrinho",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart?cart_item_id={{cartItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart"],
              "query": [
                {
                  "key": "cart_item_id",
                  "value": "{{cartItemId}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "📋 Pedidos (Checkout)",
      "item": [
        {
          "name": "1. Criar Pedido (Checkout)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.collectionVariables.set('orderId', jsonData.id);",
                  "    console.log('✅ orderId salvo: ' + jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/order",
              "host": ["{{baseUrl}}"],
              "path": ["order"]
            }
          },
          "response": []
        },
        {
          "name": "2. Listar Meus Pedidos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/order",
              "host": ["{{baseUrl}}"],
              "path": ["order"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "🔧 Pedidos (Admin)",
      "item": [
        {
          "name": "1. Listar Todos os Pedidos (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/orders?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "orders"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "2. Alterar Status do Pedido (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": \"{{orderId}}\",\n  \"status\": \"PAID\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/orders/status",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "orders", "status"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "⭐ Reviews",
      "item": [
        {
          "name": "1. Criar Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"{{productId}}\",\n  \"rating\": 5,\n  \"comentario\": \"Excelente placa de vídeo! Roda tudo no ultra.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/review",
              "host": ["{{baseUrl}}"],
              "path": ["review"]
            }
          },
          "response": []
        },
        {
          "name": "2. Listar Reviews de um Produto",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/review?product_id={{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["review"],
              "query": [
                {
                  "key": "product_id",
                  "value": "{{productId}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "🏠 Health Check",
      "item": [
        {
          "name": "API Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
